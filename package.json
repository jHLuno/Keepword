    "openai": "^5.19.1",
    "postgres": "^3.4.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electric-sql/pglite": "0.5.4",
    "@eslint/js": "^9.37.0",
    "@types/node": "^22.17.2",
    "eslint": "^9.37.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.45.0",
